{
  "name": "@daax-dev/retrospective",
  "version": "0.1.3",
  "description": "Agentic Retrospective - Evidence-based sprint retrospectives for human-agent collaboration",
  "author": "JP Workspace",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentic-retrospective": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "commands",
    "schemas",
    "docs/TESTING.md",
    "docs/fixing-telemetry-gaps.md",
    "examples",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint --ext .ts src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:snapshot": "vitest run test/snapshot",
    "test:e2e": "vitest run test/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "validate": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "validate:quick": "pnpm run typecheck && pnpm run test:unit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "date-fns": "^3.3.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^1.2.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "agentic",
    "retrospective",
    "sprint",
    "agile",
    "ai-agent",
    "claude-code",
    "gemini-cli",
    "code-review",
    "decision-log",
    "human-agent-collaboration"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daax-dev/agentic-retrospective.git"
  }
}
